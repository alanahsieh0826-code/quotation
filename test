function saveItm(){
    const idx=parseInt(document.getElementById('editITIndex').value);
    const id=document.getElementById('mItmID').value.trim();
    const name=document.getElementById('mItmName').value.trim();
    const unit=document.getElementById('mItmUnit').value.trim();
    const memo=document.getElementById('mItmMemo').value;
    const img=document.getElementById('mItmImgB64').value;
    if(!id||!name||!unit) return alert('料號代碼、品名、基準單位為必填');
    const data={id,name,unit,memo,img};
    if(idx===-1){
        if(db.items.find(i=>i.id===id)) return alert(`料號「${id}」已存在`);
        db.items.push(data);
    } else {
        const oldId=db.items[idx].id;
        if(oldId!==id){
            if(db.items.find((i,j)=>i.id===id&&j!==idx)) return alert(`料號「${id}」已存在`);
            db.warehouses.forEach(w=>{
                if(!db.inv[w.id]) db.inv[w.id]={};
                if(db.inv[w.id][oldId]){ db.inv[w.id][id]=db.inv[w.id][oldId]; delete db.inv[w.id][oldId]; }
            });
            [db.pur,db.sales,db.mfg].forEach(arr=>arr.forEach(rec=>{
                if(rec.items) rec.items.forEach(it=>{ if(it.id===oldId) it.id=id; });
                if(rec.inputs) rec.inputs.forEach(it=>{ if(it.id===oldId) it.id=id; });
                if(rec.outId===oldId) rec.outId=id;
            }));
        }
        db.items[idx]=data;
    }
    saveDB(); resetITForm(); refreshUI();
}
