function addMfgInput(){
    const id=document.getElementById('mInSel').value, q=parseFloat(document.getElementById('mInQty').value);
    const wh=document.getElementById('mInWhSel').value;
    if(!id||isNaN(q)||q<=0) return alert('請選擇投入料號並輸入有效數量');
    if(!wh) return alert('請選擇投入倉庫');
    const itm=db.items.find(i=>i.id===id); if(!itm) return alert('找不到對應料號');
    const avail=(db.inv[wh]?.[id]?.qty||0)-tMfgInputs.filter(x=>x.id===id&&x.warehouse===wh).reduce((a,b)=>a+b.qty,0);
    if(avail<q) return alert(`倉庫「${whName(wh)}」中 ${itm.name} 庫存不足（可用：${avail.toFixed(2)}）`);
    const costPerUnit=db.inv[wh]?.[id]?.avgCost||0;
    tMfgInputs.push({id,name:itm.name,qty:q,unit:itm.unit,costPerUnit,subCost:costPerUnit*q,warehouse:wh});
    document.getElementById('mTempArea').classList.remove('hidden'); renderTempMfg();
}
