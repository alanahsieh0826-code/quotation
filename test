// ── 刪除 ──────────────────────────────────────
function delD(t,idx){
    if(!confirm('確定刪除？此操作無法復原。')) return;
    const defaultWh=db.warehouses[0]?.id;
    if(t==='pur'){
        const rec=db.pur.find(x=>x.id===idx);
        if(rec&&rec.items) rec.items.forEach(x=>{
            const wh=rec.warehouse||defaultWh; if(!wh) return;
            const inv=db.inv[wh]?.[x.id]; if(inv) inv.qty-=x.qty;
        });
    } else if(t==='sales'){
        const rec=db.sales.find(x=>x.id===idx);
        if(rec&&rec.items) rec.items.forEach(x=>{
            const wh=rec.warehouse||defaultWh; if(!wh) return;
            whInv(wh,x.id).qty+=x.qty;
        });
    }
    if(typeof idx==='number') db[t].splice(idx,1);
    else db[t]=db[t].filter(x=>x.id!==idx);
    saveDB(); refreshUI();
}

// ── 備份 / 還原 ───────────────────────────────
function exportData(){
    const b=new Blob([JSON.stringify(db,null,2)],{type:'application/json'});
    const a=document.createElement('a'); a.href=URL.createObjectURL(b);
    a.download=`ERP_Data_${today()}.json`; a.click();
    setTimeout(()=>URL.revokeObjectURL(a.href),1000);
}
function importData(e){
    if(!e.target.files||!e.target.files[0]) return;
    const r=new FileReader();
    r.onload=x=>{
        try{
            const parsed=JSON.parse(x.target.result);
            ['bp','items','inv','sales','pur','exp'].forEach(k=>{ if(!parsed.hasOwnProperty(k)) throw new Error(`缺少欄位：${k}`); });
            if(!parsed.mfg) parsed.mfg=[];
            if(!parsed.txr) parsed.txr=[];
            if(!parsed.warehouses||!parsed.warehouses.length) parsed.warehouses=[{id:'WH-0001',name:'主倉庫'}];
            // 遷移舊版扁平庫存格式
            const _ks=Object.keys(parsed.inv);
            if(_ks.length>0&&typeof parsed.inv[_ks[0]]==='object'&&'qty' in (parsed.inv[_ks[0]]||{})){
                parsed.inv={[parsed.warehouses[0].id]:parsed.inv};
            }
            db=parsed; saveDB(); location.reload();
        }catch(err){ alert('還原失敗：'+err.message); }
    };
    r.readAsText(e.target.files[0]); e.target.value='';
}

// ── 轉倉 ──────────────────────────────────────
let tTxr=[];  // 暫存轉倉行
function onTxrWhChange(){
    // 重新載入料號選單並清除暫存
    refreshTxrItemSel();
    tTxr=[]; document.getElementById('txrTempArea').classList.add('hidden');
}
function refreshTxrItemSel(){
    const fromWh=document.getElementById('txrFromWh')?.value||'';
    const opt='<option value="">--選擇料號--</option>'+db.items.map(i=>{
        const qty=(db.inv[fromWh]?.[i.id]?.qty||0).toFixed(2);
        return `<option value="${escAttr(i.id)}">${escHtml(i.id)}-${escHtml(i.name)}（可用：${qty}）</option>`;
    }).join('');
    const sel=document.getElementById('txrItemSel'); if(sel) sel.innerHTML=opt;
    document.getElementById('txrAvailInfo').innerText='';
}
function onTxrItemChange(){
    const fromWh=document.getElementById('txrFromWh')?.value||'';
    const id=document.getElementById('txrItemSel')?.value||'';
    if(!id||!fromWh){ document.getElementById('txrAvailInfo').innerText=''; return; }
    const pendingQty=tTxr.filter(x=>x.id===id).reduce((a,b)=>a+b.qty,0);
    const avail=(db.inv[fromWh]?.[id]?.qty||0)-pendingQty;
    document.getElementById('txrAvailInfo').innerText=`來源倉庫可用數量：${avail.toFixed(2)}`;
}
function addTxrLine(){
    const fromWh=document.getElementById('txrFromWh').value;
    const toWh=document.getElementById('txrToWh').value;
    const id=document.getElementById('txrItemSel').value;
    const q=parseFloat(document.getElementById('txrQty').value);
    if(!fromWh||!toWh) return alert('請選擇來源倉庫與目標倉庫');
    if(fromWh===toWh) return alert('來源倉庫與目標倉庫不可相同');
    if(!id||isNaN(q)||q<=0) return alert('請選擇料號並輸入有效數量');
    const itm=db.items.find(i=>i.id===id); if(!itm) return;
    const pendingQty=tTxr.filter(x=>x.id===id).reduce((a,b)=>a+b.qty,0);
    const avail=(db.inv[fromWh]?.[id]?.qty||0)-pendingQty;
    if(avail<q) return alert(`來源倉庫「${whName(fromWh)}」中 ${itm.name} 庫存不足（可用：${avail.toFixed(2)}）`);
    tTxr.push({id,name:itm.name,unit:itm.unit,qty:q,fromWh,toWh});
    document.getElementById('txrTempArea').classList.remove('hidden');
    renderTempTxr(); onTxrItemChange();
}
function renderTempTxr(){
    document.getElementById('txrTempTbody').innerHTML=tTxr.map((x,i)=>
        `<tr>
            <td class="font-bold">${escHtml(x.name)}</td>
            <td>${escHtml(whName(x.fromWh))} → ${escHtml(whName(x.toWh))}</td>
            <td>${x.qty} ${escHtml(x.unit)}</td>
            <td class="cursor-pointer text-red-400" onclick="tTxr.splice(${i},1);renderTempTxr();onTxrItemChange();if(!tTxr.length)document.getElementById('txrTempArea').classList.add('hidden')">✕</td>
        </tr>`
    ).join('');
}
function saveTxr(){
    const d=document.getElementById('txrDate').value;
    if(!d) return alert('請選擇日期');
    if(!tTxr.length) return alert('請至少加入一項轉移品項');
    // 最終庫存驗證
    for(const x of tTxr){
        if((db.inv[x.fromWh]?.[x.id]?.qty||0)<x.qty) return alert(`「${whName(x.fromWh)}」中 ${x.name} 庫存不足`);
    }
    const memo=document.getElementById('txrMemo').value;
    tTxr.forEach(x=>{
        // 來源扣庫
        const fromInv=whInv(x.fromWh,x.id);
        const cost=fromInv.avgCost;       // 保留來源成本
        fromInv.qty-=x.qty;
        // 目標加庫（移動平均成本）
        const toInv=whInv(x.toWh,x.id);
        toInv.avgCost=(toInv.qty*toInv.avgCost+x.qty*cost)/(toInv.qty+x.qty);
        toInv.qty+=x.qty;
        db.txr.unshift({id:'TXR-'+Date.now()+'-'+Math.random().toString(36).slice(2,5),
            date:d,fromWh:x.fromWh,fromWhName:whName(x.fromWh),
            toWh:x.toWh,toWhName:whName(x.toWh),
            itemId:x.id,itemName:x.name,qty:x.qty,unit:x.unit,memo});
    });
    tTxr=[]; document.getElementById('txrTempArea').classList.add('hidden');
    saveDB(); refreshUI(); refreshTxrItemSel();
}
function renderTxr(){
    const txt=(document.getElementById('fTxr_text')?.value||'').toLowerCase();
    const from=document.getElementById('fTxr_from')?.value||'';
    const to=document.getElementById('fTxr_to')?.value||'';
    let list=db.txr.filter(x=>{
        if(!inDateRange(x.date,from,to)) return false;
        if(txt && !(x.itemName||'').toLowerCase().includes(txt) && !(x.memo||'').toLowerCase().includes(txt)
            && !(x.fromWhName||'').toLowerCase().includes(txt) && !(x.toWhName||'').toLowerCase().includes(txt)) return false;
        return true;
    });
    list=applySort(list,'txr');
    document.getElementById('txrTbody').innerHTML=list.map(x=>`<tr>
        <td>${x.date}</td>
        <td class="text-sm">${escHtml(x.fromWhName)}</td>
        <td class="text-sm font-bold" style="color:#0891b2">${escHtml(x.toWhName)}</td>
        <td class="font-bold">${escHtml(x.itemName)}</td>
        <td class="text-right">${x.qty} ${escHtml(x.unit)}</td>
        <td class="text-gray-400 text-sm">${escHtml(x.memo||'')}</td>
        <td><button onclick="delTxr('${escAttr(x.id)}')" class="text-red-400 text-sm">刪</button></td>
    </tr>`).join('');
}
function delTxr(id){
    if(!confirm('確定刪除轉倉記錄？將嘗試回沖庫存。')) return;
    const rec=db.txr.find(x=>x.id===id); if(!rec) return;
    // 回沖：目標倉庫減、來源倉庫加
    const toInv=db.inv[rec.toWh]?.[rec.itemId];
    if(toInv){
        if(toInv.qty<rec.qty) alert('警告：目標倉庫庫存不足以回沖，將強制執行。');
        toInv.qty-=rec.qty;
    }
    whInv(rec.fromWh,rec.itemId).qty+=rec.qty;
    db.txr=db.txr.filter(x=>x.id!==id);
    saveDB(); refreshUI(); refreshTxrItemSel();
}

// ── 倉庫管理 ──────────────────────────────────
function toggleWhMgmt(){
    const body=document.getElementById('whMgmtBody');
    const btn=document.getElementById('whMgmtToggle');
    const isHidden=body.classList.contains('hidden');
    body.classList.toggle('hidden');
    btn.textContent=isHidden?'▲ 收起':'▼ 展開';
}
function saveWh(){
    const name=document.getElementById('wh_name').value.trim();
    if(!name) return alert('請輸入倉庫名稱');
    if(db.warehouses.find(w=>w.name===name)) return alert('倉庫名稱已存在');
    const maxNum=db.warehouses.reduce((m,w)=>{ const n=parseInt((w.id||'').replace('WH-',''))||0; return n>m?n:m; },0);
    const id='WH-'+(maxNum+1).toString().padStart(4,'0');
    db.warehouses.push({id,name});
    if(!db.inv[id]) db.inv[id]={};
    document.getElementById('wh_name').value='';
    saveDB(); refreshUI();
}
function delWh(id){
    if(!confirm('確定刪除倉庫？此倉庫的庫存資料將一併移除。')) return;
    if(db.warehouses.length<=1) return alert('至少需要保留一個倉庫');
    db.warehouses=db.warehouses.filter(w=>w.id!==id);
    delete db.inv[id];
    saveDB(); refreshUI();
}
function renderWhTbl(){
    const tbody=document.getElementById('whTbody'); if(!tbody) return;
    tbody.innerHTML=db.warehouses.map(w=>`<tr>
        <td class="text-sm text-gray-400">${escHtml(w.id)}</td>
        <td class="font-bold">${escHtml(w.name)}</td>
        <td>${db.warehouses.length>1?`<button onclick="delWh('${escAttr(w.id)}')" class="text-red-400 text-sm">刪</button>`:'<span class="text-gray-300 text-sm">預設</span>'}</td>
    </tr>`).join('');
}

// ── 初始化 ────────────────────────────────────
window.onload=()=>{
    const td=today(), ma=monthAgo();
    ['pDate','sDate','eDate','clrDate','mDate','txrDate'].forEach(id=>{ const el=document.getElementById(id); if(el) el.value=td; });
    // 各明細預設最近一個月
    [['fPur_from','fPur_to'],['fSale_from','fSale_to'],['fExp_from','fExp_to'],['fMfg_from','fMfg_to']].forEach(([f,t])=>{
        const ef=document.getElementById(f), et=document.getElementById(t);
        if(ef) ef.value=ma; if(et) et.value=td;
    });
    refreshUI();
};
