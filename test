// ── 加工單刪除 ────────────────────────────────
function delMfg(id){
    if(!confirm('確定刪除加工單？將嘗試回沖庫存。')) return;
    const rec=db.mfg.find(x=>x.id===id); if(!rec) return;
    const defaultWh=db.warehouses[0]?.id;
    const outWh=rec.outWarehouse||defaultWh;
    if(outWh){
        const outInv=db.inv[outWh]?.[rec.outId];
        if(outInv){
            if(outInv.qty<rec.outQty) alert(`警告：產出料號「${rec.outName}」庫存不足以回沖，將強制執行。`);
            outInv.qty-=rec.outQty;
        }
    }
    rec.inputs.forEach(x=>{
        const wh=x.warehouse||defaultWh; if(!wh) return;
        whInv(wh,x.id).qty+=x.qty;
    });
    db.mfg=db.mfg.filter(x=>x.id!==id);
    expandedMfg.delete(id); saveDB(); refreshUI();
}

