    document.getElementById('mTempTbody').innerHTML=tMfgInputs.map((x,i)=>
        `<tr><td>${escHtml(x.name)}</td><td>${x.qty} ${escHtml(x.unit)}</td><td>成本 $${x.subCost.toLocaleString()}</td>
         <td class="cursor-pointer text-red-400" onclick="tMfgInputs.splice(${i},1);renderTempMfg();if(!tMfgInputs.length)document.getElementById('mTempArea').classList.add('hidden')">✕</td></tr>`
    ).join('');
    document.getElementById('mCostPreview').innerText=`投入總成本：$ ${tMfgInputs.reduce((a,b)=>a+b.subCost,0).toLocaleString()}`;
}
function saveMfg(){
    const outId=document.getElementById('mOutSel').value, outQty=parseFloat(document.getElementById('mOutQty').value), d=document.getElementById('mDate').value;
    const outWh=document.getElementById('mOutWhSel').value;
    if(!d) return alert('請選擇加工日期');
    if(!outId) return alert('請選擇產出料號');
    if(isNaN(outQty)||outQty<=0) return alert('請輸入有效的產出數量');
    if(!tMfgInputs.length) return alert('請至少加入一項投入原料');
    if(!outWh) return alert('請選擇產出倉庫');
    const outItm=db.items.find(i=>i.id===outId);
    for(const x of tMfgInputs){ if((db.inv[x.warehouse]?.[x.id]?.qty||0)<x.qty) return alert(`倉庫「${whName(x.warehouse)}」中 ${x.name} 庫存不足`); }
    const totalInputCost=tMfgInputs.reduce((a,b)=>a+b.subCost,0);
    const avgCostOut=totalInputCost/outQty;
    tMfgInputs.forEach(x=>{ const inv=whInv(x.warehouse,x.id); inv.qty-=x.qty; });
    const outInv=whInv(outWh,outId);
    outInv.avgCost=(outInv.qty*outInv.avgCost+totalInputCost)/(outInv.qty+outQty);
    outInv.qty+=outQty;
    db.mfg.unshift({id:'MFG-'+Date.now(),date:d,outId,outName:outItm?.name||outId,outQty,outWarehouse:outWh,
        inputs:[...tMfgInputs],totalInputCost,avgCostOut,memo:document.getElementById('mMemo').value});
    tMfgInputs=[]; document.getElementById('mTempArea').classList.add('hidden'); saveDB(); refreshUI();
}

