<script>
const DB_KEY = 'MyERP_Final_v9_0';
let db = JSON.parse(localStorage.getItem(DB_KEY)) || { bp:[], items:[], warehouses:[], inv:{}, sales:[], pur:[], exp:[], mfg:[], txr:[] };
if(!db.mfg) db.mfg = [];
if(!db.txr) db.txr = [];
if(!db.warehouses) db.warehouses = [];
if(!db.warehouses.length) db.warehouses.push({id:'WH-0001',name:'主倉庫'});
// 遷移舊版扁平庫存格式 { itemId:{qty,avgCost} } → { whId:{ itemId:{qty,avgCost} } }
{
    const _keys = Object.keys(db.inv);
    if(_keys.length > 0 && typeof db.inv[_keys[0]] === 'object' && 'qty' in (db.inv[_keys[0]] || {})) {
        db.inv = { [db.warehouses[0].id]: db.inv };
        localStorage.setItem(DB_KEY, JSON.stringify(db));
    }
    if(!db.inv[db.warehouses[0].id]) db.inv[db.warehouses[0].id] = {};
}

let tP=[], tS=[], tMfgInputs=[], clrT=null, editAccT=null;

// ── 排序狀態 ─────────────────────────────────
let sortState = {
    pur:  { col:'date',  dir:'desc' },
    sale: { col:'date',  dir:'desc' },
    exp:  { col:'date',  dir:'desc' },
    acc:  { col:'d',     dir:'desc' },
    inv:  { col:'id',    dir:'asc'  },
    mfg:  { col:'date',  dir:'desc' },
    txr:  { col:'date',  dir:'desc' },
    itm:  { col:'id',    dir:'asc'  }
};

function sortTable(tab, col) {
    const s = sortState[tab];
    if(s.col===col) s.dir = s.dir==='asc'?'desc':'asc';
    else { s.col=col; s.dir='asc'; }
    document.querySelectorAll(`[id^="s${tab}_"]`).forEach(el=>{ el.className='sort-arrow'; el.textContent=''; });
    const el = document.getElementById(`s${tab}_${col}`);
    if(el){ el.className='sort-arrow active'; el.textContent = s.dir==='asc'?'▲':'▼'; }
    ({pur:renderP, sale:renderS, exp:renderE, acc:renderA, inv:renderInv, mfg:renderMfg, txr:renderTxr, itm:renderITbl})[tab]();
}
function applySort(list, tab) {
    const {col,dir} = sortState[tab];
    return [...list].sort((a,b)=>{
        let av=a[col], bv=b[col];
        if(typeof av==='string') { av=av.toLowerCase(); bv=(bv||'').toLowerCase(); }
        if(av===undefined) av=''; if(bv===undefined) bv='';
        if(av<bv) return dir==='asc'?-1:1;
        if(av>bv) return dir==='asc'?1:-1;
        return 0;
    });
}

// ── 工具 ─────────────────────────────────────
function escHtml(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function escAttr(s){ return String(s||'').replace(/"/g,'&quot;').replace(/'/g,'&#39;'); }
function today(){ return new Date().toISOString().split('T')[0]; }
function monthAgo(){ const d=new Date(); d.setMonth(d.getMonth()-1); return d.toISOString().split('T')[0]; }
function inDateRange(date, from, to){
    if(from && date < from) return false;
    if(to   && date > to)   return false;
    return true;
}
// ── 倉庫庫存輔助 ──────────────────────────────
function whInv(whId, itemId){
    if(!db.inv[whId]) db.inv[whId]={};
    if(!db.inv[whId][itemId]) db.inv[whId][itemId]={qty:0,avgCost:0};
    return db.inv[whId][itemId];
}
function totalQty(itemId){
    return Object.values(db.inv).reduce((s,wh)=>s+(wh[itemId]?.qty||0),0);
}
function whName(whId){
    return db.warehouses.find(w=>w.id===whId)?.name || whId || '–';
}

// ── Lightbox ─────────────────────────────────
function openLightbox(src){ if(!src) return; document.getElementById('lightboxImg').src=src; document.getElementById('lightbox').classList.add('show'); }
function closeLightbox(){ document.getElementById('lightbox').classList.remove('show'); }
document.addEventListener('keydown', e=>{ if(e.key==='Escape') closeLightbox(); });

// ── 帳期計算 ─────────────────────────────────
function getDueDate(dateStr, bpName){
    const bp=db.bp.find(b=>b.name===bpName); if(!bp) return dateStr;
    let d=new Date(dateStr), days=parseInt(bp.days)||0;
    if(bp.type==='monthly'){ d=new Date(d.getFullYear(),d.getMonth()+1,1); d.setDate(d.getDate()+(days-1)); }
    else d.setDate(d.getDate()+days);
    return d.toISOString().split('T')[0];
}

