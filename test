<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MyERP Pro v9.0</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script>
        tailwind.config = { theme: { extend: { colors: { 'gh-bg': '#fdf8f1', 'gh-green': '#4a7c59', 'gh-blue': '#7fb3d5', 'gh-orange': '#e67e22', 'gh-text': '#5d4037' } } } }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&display=swap');
        /* ── 全域字體基準：內容 14px，標題 18px，最小不低於 14px ── */
        /* rem 基準維持 16px，text-sm = 0.875rem = 14px ✓ */
        html { font-size: 16px; }
        body { font-family: 'Noto Sans TC', sans-serif; background-color: #fdf8f1; color: #5d4037; font-size: 14px; }
        h2 { font-size: 22px; font-weight: 700; }
        h3 { font-size: 24px; font-weight: 700; }
        label { font-size: 14px; }
        button { font-size: 14px; }
        p, span, li, a { font-size: 14px; }
        .hidden-section { display: none; }
        .card { background: white; border-radius: 1.5rem; border: 1px solid #e0d5c1; padding: 2rem; box-shadow: 0 4px 15px rgba(224,213,193,0.1); margin-bottom: 2rem; }
        input, select { border: 2px solid #cbd5e1; border-radius: 0.8rem; padding: 0.8rem; margin-top: 0.4rem; font-size: 14px; outline: none; background: #fff; width: 100%; box-sizing: border-box; }
        input:focus, select:focus { border-color: #7fb3d5; box-shadow: 0 0 0 3px rgba(127,179,213,0.2); }
        table { width: 100%; border-collapse: separate; border-spacing: 0; table-layout: fixed; }
        th { background-color: #f8f1e5; padding: 0.7rem 0.8rem; border-bottom: 2px solid #e0d5c1; color: #8d6e63; text-align: left; cursor: pointer; user-select: none; white-space: nowrap; font-size: 14px; font-weight: 600; }
        th:hover { background-color: #f0e8d8; }
        td { padding: 0.65rem 0.8rem; border-bottom: 1px solid #f1f5f9; font-size: 14px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .tab-btn { background: white; border: 2px solid #e0d5c1; color: #8d6e63; padding: 0.6rem 1rem; border-radius: 1rem; font-weight: 700; transition: 0.3s; cursor: pointer; font-size: 14px; }
        .tab-active { background: #4a7c59 !important; color: white !important; transform: translateY(-2px); }
        .btn-orange { background: #e67e22; color: white; width: 100%; padding: 0.9rem; border-radius: 1rem; font-weight: 700; cursor: pointer; transition: 0.2s; border: none; font-size: 14px; }
        .btn-orange:hover { background: #d35400; }
        .status-paid { background-color: #d1fae5; color: #065f46; padding: 3px 10px; border-radius: 99px; font-size: 14px; font-weight: bold; display: inline-block; }
        .status-open { background-color: #fee2e2; color: #991b1b; padding: 3px 10px; border-radius: 99px; font-size: 14px; font-weight: bold; display: inline-block; }
        .sort-arrow { font-size: 14px; margin-left: 3px; opacity: 0.4; vertical-align: middle; }
        .sort-arrow.active { opacity: 1; color: #4a7c59; }
        .filter-bar input, .filter-bar select { margin-top: 0; padding: 0.45rem 0.7rem; font-size: 14px; }
        .filter-bar label { font-size: 14px; color: #94a3b8; }
        /* BP detail row */
        tr.bp-detail-row td { padding: 0; background: #f8faff; }
        .bp-detail-inner { padding: 0.5rem 1.5rem 1rem; }
        .bp-detail-inner table { table-layout: auto; }
        .bp-detail-inner td, .bp-detail-inner th { padding: 0.4rem 0.7rem; font-size: 14px; white-space: normal; }
        /* MFG detail row */
        tr.mfg-detail-row td { padding: 0; background: #faf5ff; }
        .mfg-detail-inner { padding: 0.4rem 1.2rem 0.8rem; }
        .mfg-detail-inner table { table-layout: auto; }
        .mfg-detail-inner td { padding: 0.35rem 0.6rem; font-size: 14px; }
        /* 儀表板數值大字 */
        .dash-value { font-size: 20px; font-weight: 900; }
        .dash-label { font-size: 14px; color: #9ca3af; font-weight: 600; }
        /* Lightbox */
        #lightbox { position: fixed; inset: 0; background: rgba(0,0,0,0.85); z-index: 9999; display: none; align-items: center; justify-content: center; cursor: zoom-out; }
        #lightbox.show { display: flex; }
        #lightbox img { max-width: 90vw; max-height: 90vh; border-radius: 0.5rem; box-shadow: 0 0 40px rgba(0,0,0,0.5); }
        /* Edit acc panel */
        #editAccPnl { background: #fffbeb; border: 2px solid #f59e0b; }
        /* thumb clickable */
        img.thumb-click { cursor: zoom-in; transition: opacity 0.15s; }
        img.thumb-click:hover { opacity: 0.8; }
    </style>
</head>
<body class="p-4 md:p-8">

<!-- 圖片放大 Lightbox -->
<div id="lightbox" onclick="closeLightbox()">
    <img id="lightboxImg" src="" alt="">
</div>

<div class="max-w-7xl mx-auto">

    <!-- 營運羅盤 -->
    <div class="card bg-gradient-to-br from-orange-50 to-white">
        <div class="flex justify-between items-center mb-6">
            <h2 class="font-bold text-gh-green">營運羅盤</h2>
            <div class="flex gap-2">
                <button onclick="exportData()" class="bg-emerald-600 text-white px-4 py-2 rounded-xl text-sm font-bold">備份</button>
                <input type="file" id="importFile" class="hidden" onchange="importData(event)">
                <button onclick="document.getElementById('importFile').click()" class="bg-blue-400 text-white px-4 py-2 rounded-xl text-sm font-bold">還原</button>
            </div>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
            <div class="text-center border-r border-dashed border-orange-200"><p class="dash-label">總營收</p><p id="dashSales" class="dash-value">$ 0</p></div>
            <div class="text-center border-r border-dashed border-orange-200 text-orange-600"><p class="dash-label">銷貨成本</p><p id="dashCost" class="dash-value">$ 0</p></div>
            <div class="text-center border-r border-dashed border-orange-200 text-rose-500"><p class="dash-label">支出費用</p><p id="dashExp" class="dash-value">$ 0</p></div>
            <div class="text-center border-r border-dashed border-orange-200 text-gh-green"><p class="dash-label">預估淨利</p><p id="dashProfit" class="dash-value">$ 0</p></div>
            <div class="text-center text-gh-blue"><p class="dash-label">待沖總額</p><p id="dashOpen" class="dash-value">$ 0</p></div>
        </div>
    </div>

    <!-- Tab 導覽 -->
    <div class="flex flex-wrap gap-2 mb-6 pb-4 border-b border-dashed border-slate-300">
        <button onclick="switchTab('pur', this)" class="tab-btn tab-active">📦 進貨</button>
        <button onclick="switchTab('sale', this)" class="tab-btn">💰 銷售</button>
        <button onclick="switchTab('exp', this)" class="tab-btn">💸 支出</button>
        <button onclick="switchTab('acc', this)" class="tab-btn">🧾 對帳</button>
        <button onclick="switchTab('inv', this)" class="tab-btn">🏠 庫存</button>
        <button onclick="switchTab('txr', this)" class="tab-btn">🔄 轉倉</button>
        <button onclick="switchTab('mfg', this)" class="tab-btn">🔧 加工</button>
        <button onclick="switchTab('bpm', this)" class="tab-btn">👥 夥伴設定</button>
        <button onclick="switchTab('itm', this)" class="tab-btn">🏷️ 料號設定</button>
    </div>

    <div id="mainContent">

        <!-- ===== 進貨 ===== -->
        <section id="pur-sec" class="tab-content">
            <div class="card">
                <h3 class="font-bold mb-4 text-gh-green">新增進貨單</h3>
                <div class="grid grid-cols-1 md:grid-cols-4 gap-4 border-b pb-6 mb-6">
                    <div><label>日期</label><input type="date" id="pDate"></div>
                    <div><label>供應商</label><select id="pVendSel"></select></div>
                    <div><label>倉庫</label><select id="pWhSel"></select></div>
                    <div><label>備註</label><input type="text" id="pMemo"></div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-4 gap-4 items-start">
                    <div class="md:col-span-2">
                        <label>產品項目</label>
                        <div class="flex gap-2 items-center mt-1">
                            <select id="pItemSel" onchange="onPItemChange()" class="flex-1 mt-0"></select>
                            <img id="pItemThumb" src="" class="w-12 h-12 rounded-lg object-cover hidden border border-gray-200 flex-shrink-0 thumb-click" onclick="openLightbox(this.src)">
                            <button type="button" onclick="toggleQuickAddItem()" class="text-sm bg-amber-100 text-amber-800 border border-amber-300 px-2 py-1 rounded-lg whitespace-nowrap flex-shrink-0" style="margin-top:0">＋新料號</button>
                        </div>
                        <div id="quickItemForm" class="hidden mt-3 p-3 bg-amber-50 border border-amber-200 rounded-xl">
                            <p class="text-sm font-bold text-amber-700 mb-2">快速新增料號</p>
                            <div class="grid grid-cols-3 gap-2 mb-2">
                                <input type="text" id="qItmID" placeholder="料號代碼" style="margin-top:0">
                                <input type="text" id="qItmName" placeholder="品名" style="margin-top:0">
                                <input type="text" id="qItmUnit" placeholder="單位" style="margin-top:0">
                            </div>
                            <div class="flex gap-2 items-center mb-2">
                                <label class="text-sm text-gray-500 whitespace-nowrap">圖片</label>
                                <input type="file" accept="image/*" id="qItmImgFile" onchange="handleImgUpload(event,'qItmImgB64','qItmThumb')" style="margin-top:0;border:none;padding:0;width:auto">
                                <img id="qItmThumb" src="" class="w-10 h-10 hidden object-cover rounded border">
                            </div>
                            <input type="hidden" id="qItmImgB64" value="">
                            <div class="flex gap-2">
                                <button type="button" onclick="saveQuickItem()" class="flex-1 bg-amber-400 text-white rounded-lg p-1.5 text-sm font-bold">確認新增</button>
                                <button type="button" onclick="toggleQuickAddItem()" class="bg-gray-200 text-gray-600 rounded-lg px-3 p-1.5 text-sm">取消</button>
                            </div>
                        </div>
                    </div>
                    <div><label>數量</label><input type="number" id="pQty" value="1"></div>
                    <div><label>金額</label><input type="number" id="pTotalIn" value="0"></div>
                    <button type="button" onclick="addP()" class="md:col-span-4 bg-gh-green text-white p-3 rounded-xl font-bold">+ 加入清單</button>
                </div>
                <div id="pTempArea" class="mt-4 p-4 bg-emerald-50 rounded-xl hidden">
                    <table class="w-full text-sm" style="table-layout:auto"><tbody id="pTempTbody"></tbody></table>
                </div>
                <button type="button" onclick="saveP()" class="btn-orange mt-6">確認單據入庫</button>
            </div>
            <div class="card overflow-x-auto">
                <h3 class="font-bold mb-3">進貨明細</h3>
                <div class="filter-bar flex flex-wrap gap-2 mb-3 items-center">
                    <input type="text" id="fPur_text" placeholder="🔍 供應商/品名/備註" oninput="renderP()" style="width:180px;margin-top:0">
                    <label class="text-sm text-gray-500">從</label>
                    <input type="date" id="fPur_from" onchange="renderP()" style="width:140px;margin-top:0">
                    <label class="text-sm text-gray-500">至</label>
                    <input type="date" id="fPur_to" onchange="renderP()" style="width:140px;margin-top:0">
                </div>
                <table id="pTable" style="table-layout:auto">
                    <thead><tr>
                        <th onclick="sortTable('pur','date')" style="width:90px">日期<span id="spur_date" class="sort-arrow active">▼</span></th>
                        <th onclick="sortTable('pur','vendor')" style="width:100px">供應商<span id="spur_vendor" class="sort-arrow"></span></th>
                        <th onclick="sortTable('pur','warehouseName')" style="width:80px">倉庫<span id="spur_warehouseName" class="sort-arrow"></span></th>
                        <th onclick="sortTable('pur','itemName')" style="width:110px">產品項目<span id="spur_itemName" class="sort-arrow"></span></th>
                        <th style="width:50px">圖片</th>
                        <th onclick="sortTable('pur','qty')" style="width:60px">數量<span id="spur_qty" class="sort-arrow"></span></th>
                        <th onclick="sortTable('pur','unitPrice')" style="width:80px">單價<span id="spur_unitPrice" class="sort-arrow"></span></th>
                        <th onclick="sortTable('pur','sub')" style="width:80px">金額<span id="spur_sub" class="sort-arrow"></span></th>
                        <th style="width:100px">備註</th>
                        <th style="width:50px">操作</th>
                    </tr></thead>
                    <tbody id="pTbody"></tbody>
                </table>
            </div>
        </section>

        <!-- ===== 銷售 ===== -->
        <section id="sale-sec" class="tab-content hidden-section">
            <div class="card">
                <h3 class="font-bold mb-4 text-gh-blue">建立銷售單</h3>
                <div class="grid grid-cols-1 md:grid-cols-4 gap-4 border-b pb-6 mb-6">
                    <div><label>日期</label><input type="date" id="sDate"></div>
                    <div><label>客戶</label><select id="sCustSel"></select></div>
                    <div><label>倉庫</label><select id="sWhSel"></select></div>
                    <div><label>備註</label><input type="text" id="sMemo"></div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
                    <div class="md:col-span-2">
                        <label>產品</label>
                        <div class="flex gap-2 items-center mt-1">
                            <select id="sItemSel" onchange="onSItemChange()" class="flex-1 mt-0"></select>
                            <img id="sItemThumb" src="" class="w-12 h-12 rounded-lg object-cover hidden border border-gray-200 flex-shrink-0 thumb-click" onclick="openLightbox(this.src)">
                        </div>
                    </div>
                    <div><label>數量</label><input type="number" id="sQty" value="1"></div>
                    <div><label>金額</label><input type="number" id="sTotalIn" value="0"></div>
                    <button type="button" onclick="addS()" class="md:col-span-4 bg-gh-blue text-white p-3 rounded-xl font-bold">+ 加入清單</button>
                </div>
                <div id="sTempArea" class="mt-4 p-4 bg-blue-50 rounded-xl hidden">
                    <table class="w-full text-sm" style="table-layout:auto"><tbody id="sTempTbody"></tbody></table>
                </div>
                <button type="button" onclick="saveS()" class="btn-orange mt-6">確認銷售過帳</button>
            </div>
            <div class="card overflow-x-auto">
                <h3 class="font-bold mb-3">銷售明細</h3>
                <div class="filter-bar flex flex-wrap gap-2 mb-3 items-center">
                    <input type="text" id="fSale_text" placeholder="🔍 客戶/品名/備註" oninput="renderS()" style="width:180px;margin-top:0">
                    <label class="text-sm text-gray-500">從</label>
                    <input type="date" id="fSale_from" onchange="renderS()" style="width:140px;margin-top:0">
                    <label class="text-sm text-gray-500">至</label>
                    <input type="date" id="fSale_to" onchange="renderS()" style="width:140px;margin-top:0">
                </div>
                <table id="sTable" style="table-layout:auto">
                    <thead><tr>
                        <th onclick="sortTable('sale','date')" style="width:90px">日期<span id="ssale_date" class="sort-arrow active">▼</span></th>
                        <th onclick="sortTable('sale','customer')" style="width:100px">客戶<span id="ssale_customer" class="sort-arrow"></span></th>
                        <th onclick="sortTable('sale','warehouseName')" style="width:80px">倉庫<span id="ssale_warehouseName" class="sort-arrow"></span></th>
                        <th onclick="sortTable('sale','itemName')" style="width:110px">產品<span id="ssale_itemName" class="sort-arrow"></span></th>
                        <th style="width:50px">圖片</th>
                        <th onclick="sortTable('sale','qty')" style="width:60px">數量<span id="ssale_qty" class="sort-arrow"></span></th>
                        <th onclick="sortTable('sale','unitPrice')" style="width:80px">單價<span id="ssale_unitPrice" class="sort-arrow"></span></th>
                        <th onclick="sortTable('sale','sub')" style="width:80px">金額<span id="ssale_sub" class="sort-arrow"></span></th>
                        <th style="width:100px">備註</th>
                        <th style="width:50px">操作</th>
                    </tr></thead>
                    <tbody id="sTbody"></tbody>
                </table>
            </div>
        </section>

        <!-- ===== 支出 ===== -->
        <section id="exp-sec" class="tab-content hidden-section">
            <div class="card">
                <h3 class="font-bold mb-4 text-rose-500">支出登記</h3>
                <div class="grid grid-cols-1 md:grid-cols-5 gap-4 items-end">
                    <div><label>日期</label><input type="date" id="eDate"></div>
                    <div><label>對象</label><select id="eVendSel"></select></div>
                    <div><label>類別</label><select id="eCat"><option>租金</option><option>薪資</option><option>水電</option><option>雜支</option></select></div>
                    <div><label>金額</label><input type="number" id="eAmt" placeholder="0"></div>
                    <div><label>備註</label><input type="text" id="eMemo"></div>
                    <button type="button" onclick="saveE()" class="md:col-span-5 bg-rose-500 text-white p-3 rounded-xl font-bold">儲存支出</button>
                </div>
            </div>
            <div class="card overflow-x-auto">
                <h3 class="font-bold mb-3">支出明細</h3>
                <div class="filter-bar flex flex-wrap gap-2 mb-3 items-center">
                    <input type="text" id="fExp_text" placeholder="🔍 對象/備註" oninput="renderE()" style="width:160px;margin-top:0">
                    <select id="fExp_cat" onchange="renderE()" style="width:100px;margin-top:0">
                        <option value="all">全部類別</option><option>租金</option><option>薪資</option><option>水電</option><option>雜支</option>
                    </select>
                    <label class="text-sm text-gray-500">從</label>
                    <input type="date" id="fExp_from" onchange="renderE()" style="width:140px;margin-top:0">
                    <label class="text-sm text-gray-500">至</label>
                    <input type="date" id="fExp_to" onchange="renderE()" style="width:140px;margin-top:0">
                </div>
                <table id="eTable" style="table-layout:auto">
                    <thead><tr>
                        <th onclick="sortTable('exp','date')" style="width:90px">日期<span id="sexp_date" class="sort-arrow active">▼</span></th>
                        <th onclick="sortTable('exp','vendor')" style="width:100px">對象<span id="sexp_vendor" class="sort-arrow"></span></th>
                        <th onclick="sortTable('exp','cat')" style="width:80px">類別<span id="sexp_cat" class="sort-arrow"></span></th>
                        <th onclick="sortTable('exp','amount')" style="width:90px">金額<span id="sexp_amount" class="sort-arrow"></span></th>
                        <th>備註</th>
                        <th style="width:50px">操作</th>
                    </tr></thead>
                    <tbody id="eTbody"></tbody>
                </table>
            </div>
        </section>

        <!-- ===== 對帳 ===== -->
        <section id="acc-sec" class="tab-content hidden-section">
            <div class="card">
                <h3 class="font-bold mb-4 text-gh-orange">全能對帳管理</h3>
                <!-- 沖銷面板 -->
                <div id="clrPnl" class="bg-blue-50 border-2 border-blue-200 p-4 rounded-2xl mb-4 hidden">
                    <div id="clrInf" class="font-bold text-blue-700 mb-3 text-sm"></div>
                    <div class="flex flex-wrap gap-2">
                        <input type="date" id="clrDate" style="width:150px;margin-top:0">
                        <input type="text" id="clrMemo" placeholder="沖銷備註" style="flex:1;margin-top:0">
                        <button type="button" onclick="doClr()" class="bg-blue-600 text-white px-6 py-2 rounded-xl font-bold text-sm">執行沖銷</button>
                        <button type="button" onclick="cancelClr()" class="bg-gray-200 text-gray-600 px-4 py-2 rounded-xl text-sm">取消</button>
                    </div>
                </div>
                <!-- 修改面板 -->
                <div id="editAccPnl" class="p-4 rounded-2xl mb-4 hidden">
                    <div id="editAccInf" class="font-bold text-amber-700 mb-3 text-sm"></div>
                    <div class="flex flex-wrap gap-2">
                        <input type="date" id="editAccDate" style="width:150px;margin-top:0">
                        <input type="text" id="editAccMemo" placeholder="備註" style="flex:1;margin-top:0">
                        <button type="button" onclick="doEditAcc()" class="bg-amber-500 text-white px-6 py-2 rounded-xl font-bold text-sm">儲存修改</button>
                        <button type="button" onclick="cancelEditAcc()" class="bg-gray-200 text-gray-600 px-4 py-2 rounded-xl text-sm">取消</button>
                    </div>
                </div>
                <!-- 篩選 -->
                <div class="filter-bar flex flex-wrap gap-2 mb-3 items-center">
                    <input type="text" id="fAcc_text" placeholder="🔍 搜尋對象" oninput="renderA()" style="width:150px;margin-top:0">
                    <select id="fAcc_kind" onchange="renderA()" style="width:110px;margin-top:0">
                        <option value="all">全部類別</option><option value="AR">AR 銷售</option><option value="AP">AP 進貨</option><option value="EX">EX 支出</option>
                    </select>
                    <select id="fAcc_status" onchange="renderA()" style="width:100px;margin-top:0">
                        <option value="open" selected>待沖</option><option value="paid">已結</option><option value="all">全部</option>
                    </select>
                    <span class="text-sm text-gray-400 ml-1">交易日</span>
                    <input type="date" id="fAcc_dFrom" onchange="renderA()" style="width:140px;margin-top:0">
                    <span class="text-sm text-gray-400">~</span>
                    <input type="date" id="fAcc_dTo" onchange="renderA()" style="width:140px;margin-top:0">
                    <span class="text-sm text-gray-400 ml-1">到期日</span>
                    <input type="date" id="fAcc_ddFrom" onchange="renderA()" style="width:140px;margin-top:0">
                    <span class="text-sm text-gray-400">~</span>
                    <input type="date" id="fAcc_ddTo" onchange="renderA()" style="width:140px;margin-top:0">
                </div>
                <table id="accTable" style="table-layout:auto">
