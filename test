        if(whFilter==='all'){
            let totalVal=0, totalQ=0;
            Object.values(db.inv).forEach(wh=>{ const e=wh[it.id]; if(e){ totalVal+=e.qty*e.avgCost; totalQ+=e.qty; }});
            return {...it, qty:totalQ, avgCost:totalQ>0?totalVal/totalQ:0};
        } else {
            const e=db.inv[whFilter]?.[it.id];
            return {...it, qty:e?.qty||0, avgCost:e?.avgCost||0};
        }
    });
    if(hideZero) list=list.filter(it=>it.qty>0);
    list=applySort(list,'inv');
